"fontSize\":\"xx-large\"} -->\n<h2 class=\"wp-block-heading gogh-el-2 has-xx-large-font-size\">Drag this headline somewhere fun</h2>\n<!-- /wp:heading -->\n\n<!-- wp:paragraph {\"className\":\"gogh-el-3\"} -->\n<p class=\"gogh-el-3\">This whole page is a canvas. Grab anything, pull it around, and watch the guides and spacing labels help you line things up.</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:buttons {\"className\":\"gogh-el-4\"} -->\n<div class=\"wp-block-buttons gogh-el-4\"><!-- wp:button -->\n<div class=\"wp-block-button\"><a class=\"wp-block-button__link wp-element-button\" href=\"#\">Publish when ready</a></div>\n<!-- /wp:button --></div>\n<!-- /wp:buttons -->\n\n<!-- wp:buttons {\"className\":\"gogh-el-5\"} -->\n<div class=\"wp-block-buttons gogh-el-5\"><!-- wp:button {\"className\":\"gogh-ghost\",\"url\":\"https://github.com/jamiemarsland/gogh-editor\"} -->\n<div class=\"wp-block-button gogh-ghost\"><a class=\"wp-block-button__link wp-element-button\" href=\"https://github.com/jamiemarsland/gogh-editor\">Star on GitHub</a></div>\n<!-- /wp:button --></div>\n<!-- /wp:buttons -->\n\n<!-- wp:group {\"className\":\"gogh-el-6\",\"layout\":{\"type\":\"default\"}} -->\n<div class=\"wp-block-group gogh-el-6\"></div>\n<!-- /wp:group -->\n</div></div>\n<!-- /wp:gogh/section -->\n\n<!-- wp:group {\"layout\":{\"type\":\"constrained\"}} --><div class=\"wp-block-group\"><!-- wp:heading --><h2 class=\"wp-block-heading\">This section was built in Gutenberg</h2><!-- /wp:heading --><!-- wp:paragraph --><p>Hover it and click the little \"Make freeform\" button \u2014 Gogh recreates it as a draggable canvas, pixel for pixel.</p><!-- /wp:paragraph --><!-- wp:buttons --><div class=\"wp-block-buttons\"><!-- wp:button --><div class=\"wp-block-button\"><a class=\"wp-block-button__link wp-element-button\" href=\"https://github.com/jamiemarsland/gogh-editor\">See the code on GitHub</a></div><!-- /wp:button --></div><!-- /wp:buttons --></div><!-- /wp:group -->\nGOGHEOT;\n$page_id = wp_insert_post( array(\n    'import_id'    => 99,\n    'post_type'    => 'page',\n    'post_status'  => 'publish',\n    'post_title'   => 'Gogh Editor',\n    'post_content' => $content,\n) );\nrequire_once ABSPATH . 'wp-admin/includes/media.php';\nrequire_once ABSPATH . 'wp-admin/includes/file.php';\nrequire_once ABSPATH . 'wp-admin/includes/image.php';\nmedia_sideload_image( 'https://commons.wikimedia.org/wiki/Special:FilePath/Vincent_van_Gogh_-_Wheat_Field_with_Cypresses_-_Google_Art_Project.jpg?width=1280', $page_id, 'Vincent van Gogh painting', 'id' );\nmedia_sideload_image( 'https://commons.wikimedia.org/wiki/Special:FilePath/Van_Gogh_-_Starry_Night_-_Google_Art_Project.jpg?width=1280', $page_id, 'Vincent van Gogh painting', 'id' );\nmedia_sideload_image( 'https://commons.wikimedia.org/wiki/Special:FilePath/Vincent_Willem_van_Gogh_127.jpg?width=1280', $page_id, 'Vincent van Gogh painting', 'id' );\nmedia_sideload_image( 'https://commons.wikimedia.org/wiki/Special:FilePath/Vincent_van_Gogh_-_Almond_blossom_-_Google_Art_Project.jpg?width=1280', $page_id, 'Vincent van Gogh painting', 'id' );\n"
