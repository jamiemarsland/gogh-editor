      "code": "<?php\nrequire '/wordpress/wp-load.php';\nwp_set_current_user( 1 ); // admin: keeps kses from stripping gogh's style/model tags\n$content = <<<'GOGHEOT'\n<!-- wp:gogh/section -->\n<div class=\"wp-block-gogh-section alignfull gogh-wrap\"><style class=\"gogh-style\">/* generated by gogh */\n.gogh-wrap { container-type: inline-size; margin-block: 0 !important; }\n.gogh-section.gogh-sec-1 {\n  display: grid;\n  position: relative;\n  background: color-mix(in srgb, var(--wp--preset--color--contrast, currentColor) 6%, var(--wp--preset--color--base, transparent));\n  grid-template-columns: 6cqw 17.5cqw 1.67cqw 1.67cqw 15cqw 9.17cqw 15cqw 4.83cqw 23.17cqw 6cqw;\n  grid-template-rows:\n    minmax(5.33cqw, max-content)\n    minmax(3cqw, max-content)\n    minmax(1.33cqw, max-content)\n    minmax(2cqw, max-content)\n    minmax(3.33cqw, max-content)\n    minmax(14.17cqw, max-content)\n    minmax(4.5cqw, max-content)\n    minmax(5.5cqw, max-content)\n    minmax(4.5cqw, max-content)\n    minmax(6.17cqw, max-content);\n}\n.gogh-section.gogh-sec-1 > * { margin: 0 !important; min-width: 0; }\n.gogh-section.gogh-sec-1 .gogh-el-1 { grid-area: 2 / 2 / 4 / 5; z-index: 1; display: flex; align-items: center; gap: 0.6em; height: 100%; background: #fff; color: #141519; border-radius: clamp(6px, 1.2cqw, 14px); padding: 0 1.1em; font-size: clamp(11px, 1.15cqw, 14px); font-weight: 600; box-shadow: 0 14px 34px -12px rgba(0,0,0,0.55); white-space: nowrap; }\n.gogh-section.gogh-sec-1 .gogh-el-2 { grid-area: 5 / 2 / 6 / 8; z-index: 2; align-self: start; }\n.gogh-section.gogh-sec-1 .gogh-el-3 { grid-area: 7 / 2 / 8 / 7; z-index: 3; align-self: start; }\n.gogh-section.gogh-sec-1 .gogh-el-4 { grid-area: 9 / 2 / 10 / 3; z-index: 4;  }\n.gogh-section.gogh-sec-1 .gogh-el-5 { grid-area: 9 / 4 / 10 / 6; z-index: 5;  }\n.gogh-section.gogh-sec-1 .gogh-el-6 { grid-area: 3 / 9 / 10 / 10; z-index: 6; border-radius: clamp(8px, 1.5cqw, 20px); background: linear-gradient(140deg, #e8b04b 0%, #d9745a 55%, #7a3b52 100%); }\n.gogh-section.gogh-sec-1 .gogh-badge::before { content: \"\u2605\"; width: 1.9em; height: 1.9em; flex: none; border-radius: 50%; background: #e8b04b; display: grid; place-items: center; color: #141519; }\n.gogh-section.gogh-sec-1 .wp-block-button, .gogh-section.gogh-sec-1 .wp-block-button__link { width: 100%; height: 100%; }\n.gogh-section.gogh-sec-1 .wp-block-button__link { display: flex; align-items: center; justify-content: center; box-sizing: border-box; white-space: nowrap; }\n.gogh-section.gogh-sec-1 .gogh-ghost .wp-block-button__link { background: transparent; color: inherit; box-shadow: inset 0 0 0 1.5px currentColor; }\n\n@container (max-width: 700px) {\n  .gogh-section.gogh-sec-1 { grid-template-columns: 7cqw 1fr 7cqw; grid-template-rows: none; grid-auto-rows: auto; row-gap: 6cqw; padding: 9cqw 0; }\n  .gogh-section.gogh-sec-1 .gogh-el-1 { grid-area: auto; grid-column: 2; order: 0; width: max-content; height: 44px; }\n  .gogh-section.gogh-sec-1 .gogh-el-2 { grid-area: auto; grid-column: 2; order: 1; }\n  .gogh-section.gogh-sec-1 .gogh-el-3 { grid-area: auto; grid-column: 2; order: 2; }\n  .gogh-section.gogh-sec-1 .gogh-el-4 { grid-area: auto; grid-column: 2; order: 3; }\n  .gogh-section.gogh-sec-1 .gogh-el-5 { grid-area: auto; grid-column: 2; order: 4; }\n  .gogh-section.gogh-sec-1 .gogh-el-6 { grid-area: auto; grid-column: 2; order: 5; aspect-ratio: 278 / 420; }\n  .gogh-section.gogh-sec-1 .wp-block-button, .gogh-section.gogh-sec-1 .wp-block-button__link { width: max-content; height: 44px; padding: 0 24px; }\n}</style><script type=\"application/json\" class=\"gogh-model\">{\"version\":2,\"designW\":1200,\"minH\":560,\"bg\":\"color-mix(in srgb, var(--wp--preset--color--contrast, currentColor) 6%, var(--wp--preset--color--base, transparent))\",\"divider\":null,\"bgImage\":null,\"bgId\":null,\"elements\":[{\"type\":\"badge\",\"x\":72,\"y\":64,\"w\":250,\"h\":52,\"text\":\"Fresh off the canvas\",\"ghost\":false,\"cool\":false,\"src\":nu